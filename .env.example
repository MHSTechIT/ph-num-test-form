# Shared password to enter the dashboard
DASHBOARD_PASSWORD=changeme

# 32+ character random string used to sign the session cookie
SESSION_SECRET=replace-with-a-long-random-string-min-32-chars

# Spreadsheet ID (from the URL: docs.google.com/spreadsheets/d/<THIS_PART>/edit)
GOOGLE_SHEETS_ID=1URoRKBYb8g_CRhoerD0ULX84pMRCRpnXT4dU6Z3Ubgo

# Google OAuth user credentials (offline access). See README for how to mint these.
GOOGLE_OAUTH_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-...
GOOGLE_OAUTH_REFRESH_TOKEN=1//...

# Destination "Accounts" spreadsheet that the "Add to Accounts" buttons append to.
# Optional — falls back to the sheet ID hardcoded in lib/google-sheets.ts.
ACCOUNTS_SHEETS_ID=1cUFTVpZf-O-e-On2KwHqbl_Jpfwqqvmnf0_4H9xGJ50
