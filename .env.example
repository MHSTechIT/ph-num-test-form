# Shared password to enter the dashboard
DASHBOARD_PASSWORD=changeme

# 32+ character random string used to sign the session cookie
SESSION_SECRET=replace-with-a-long-random-string-min-32-chars

# Apps Script web app URL (the deployment URL ending in /exec)
APPS_SCRIPT_URL=https://script.google.com/macros/s/AKfycb.../exec

# Shared bearer token: must match the API_TOKEN script property in Apps Script
APPS_SCRIPT_TOKEN=replace-with-a-long-random-string
